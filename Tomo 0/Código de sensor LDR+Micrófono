int valorLdr = 0;
int estadoMic = 0;

void setup() {
  // put your setup code here, to run once:
  Serial.begin(9600);
  pinMode(2,INPUT);
}

void loop() {
  // put your main code here, to run repeatedly:
  int valorAleatorio = analogRead(A1);

  valorLdr = valorAleatorio/2;
  int estadoMic = !digitalRead(2)*512; //valor de 0 o 1, multiplico por 512

  Serial.println(estadoMic+valorLdr);
  delay(70);
}
